# Database
DATABASE_URL=postgresql://computicket:computicket@localhost:5432/computicket?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# API
PORT=4000
NODE_ENV=development
JWT_SECRET=dev_unsafe_change_me_in_production
JWT_EXPIRES_IN=7d

# Paystack (use test keys for development)
PAYSTACK_PUBLIC_KEY=pk_test_replace_me
PAYSTACK_SECRET_KEY=sk_test_replace_me

# Email (Postmark). Leave POSTMARK_SERVER_TOKEN unset to log emails
# to stdout instead of sending them.
POSTMARK_SERVER_TOKEN=
MAIL_FROM=tickets@computicket.ng

# SMS (Termii). Leave TERMII_API_KEY unset to log SMSes to stdout
# instead of sending them.
TERMII_API_KEY=
TERMII_SENDER=Computicket

# Anthropic (AI support chatbot). Leave ANTHROPIC_API_KEY unset to fall back
# to the deterministic keyword matcher.
ANTHROPIC_API_KEY=

# NFT mint vouchers. Used to HMAC-sign the (recipient, tokenId, tokenURI,
# expiresAt) payload that a deployed ERC-721 lazy-mint contract will later
# verify. Falls back to JWT_SECRET in dev.
NFT_SIGNING_KEY=

# Public base URL embedded in NFT metadata image/external_url fields.
PUBLIC_API_URL=http://localhost:4000/v1

# Public web URL used in email links (verification, password reset)
PUBLIC_WEB_URL=http://localhost:3000

# App secret used to derive the AES-256-GCM key that encrypts TOTP
# secrets at rest. Falls back to JWT_SECRET in dev.
APP_KEY=

# Web app
NEXT_PUBLIC_API_URL=http://localhost:4000/v1
