# Database
DATABASE_URL=postgresql://computicket:computicket@localhost:5432/computicket?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# API
PORT=4000
NODE_ENV=development
JWT_SECRET=dev_unsafe_change_me_in_production
JWT_EXPIRES_IN=7d

# Paystack (use test keys for development)
PAYSTACK_PUBLIC_KEY=pk_test_replace_me
PAYSTACK_SECRET_KEY=sk_test_replace_me

# Email (Postmark). Leave POSTMARK_SERVER_TOKEN unset to log emails
# to stdout instead of sending them.
POSTMARK_SERVER_TOKEN=
MAIL_FROM=tickets@computicket.ng

# Web app
NEXT_PUBLIC_API_URL=http://localhost:4000/v1
