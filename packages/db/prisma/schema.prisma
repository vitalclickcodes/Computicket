// Computicket Nigeria — Phase 1 schema
// Covers: identity, organizers, events, ticket types, orders, tickets.
// Travel/hotels/vouchers land in later phases.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Identity ----------

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  phone        String?  @unique
  name         String?
  passwordHash String?
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships OrganizerMember[]
  orders      Order[]
}

// ---------- Organizers (multi-vendor) ----------

enum OrganizerStatus {
  PENDING
  APPROVED
  SUSPENDED
}

enum OrganizerRole {
  OWNER
  MANAGER
  FINANCE
  MARKETING
  SCANNER
  READ_ONLY
}

model Organizer {
  id               String          @id @default(cuid())
  slug             String          @unique
  name             String
  status           OrganizerStatus @default(PENDING)
  description      String?
  logoUrl          String?
  website          String?
  // Paystack split payout integration
  paystackSubaccountCode String?
  payoutBankCode         String?
  payoutAccountNumber    String?
  payoutAccountName      String?
  // KYC / admin review
  kycNotes               String?
  approvedAt             DateTime?
  approvedById           String?
  commissionBps    Int             @default(800) // 8% default
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  members          OrganizerMember[]
  events           Event[]
  apiKeys          ApiKey[]
  webhookEndpoints WebhookEndpoint[]
  promoCodes       PromoCode[]
  busRoutes        BusRoute[]
}

model BusRoute {
  id              String   @id @default(cuid())
  organizerId     String
  fromCity        String
  toCity          String
  // Typical trip duration in minutes; used for display and rough arrival estimates.
  durationMinutes Int
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())

  organizer Organizer @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  trips     Event[]

  @@index([fromCity, toCity])
  @@index([organizerId])
}

enum PromoCodeType {
  PERCENTAGE
  FIXED
}

model PromoCode {
  id           String        @id @default(cuid())
  organizerId  String
  // Optional: scope the code to a specific event. NULL = applies to any
  // event owned by this organizer.
  eventId      String?
  code         String
  type         PromoCodeType
  // PERCENTAGE: basis points (1000 = 10%). FIXED: kobo amount off subtotal.
  value        Int
  maxUses      Int?
  usesCount    Int           @default(0)
  expiresAt    DateTime?
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())

  organizer Organizer @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  event     Event?    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([organizerId, code])
  @@index([organizerId])
}

model ApiKey {
  id          String    @id @default(cuid())
  organizerId String
  name        String
  // First 16 chars of the raw key, for display (e.g. "ctng_live_a1b2…")
  prefix      String
  // SHA-256 of the raw key. Indexed for O(1) lookup at request time.
  hashedKey   String    @unique
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  organizer Organizer @relation(fields: [organizerId], references: [id], onDelete: Cascade)

  @@index([organizerId])
}

model WebhookEndpoint {
  id            String   @id @default(cuid())
  organizerId   String
  url           String
  signingSecret String
  // Event names this endpoint subscribes to, e.g. ["order.paid","order.refunded"]
  eventTypes    String[]
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())

  organizer Organizer @relation(fields: [organizerId], references: [id], onDelete: Cascade)

  @@index([organizerId])
}

model OrganizerMember {
  id          String        @id @default(cuid())
  organizerId String
  userId      String
  role        OrganizerRole
  createdAt   DateTime      @default(now())

  organizer Organizer @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizerId, userId])
}

// ---------- Catalog: Events ----------

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum EventType {
  EVENT
  BUS_TRIP
}

model Event {
  id          String      @id @default(cuid())
  organizerId String
  slug        String      @unique
  title       String
  description String?
  venue       String
  city        String
  startsAt    DateTime
  endsAt      DateTime
  coverUrl    String?
  status      EventStatus @default(DRAFT)
  type        EventType   @default(EVENT)
  // For type=BUS_TRIP: optional link to a parent route so buyers can
  // search by from/to. Trips also use venue=boarding terminal,
  // city=fromCity for compatibility with the existing event list.
  busRouteId  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  organizer   Organizer    @relation(fields: [organizerId], references: [id])
  busRoute    BusRoute?    @relation(fields: [busRouteId], references: [id])
  ticketTypes TicketType[]
  orders      Order[]
  promoCodes  PromoCode[]

  @@index([status, startsAt])
  @@index([organizerId])
  @@index([type, status, startsAt])
}

model TicketType {
  id          String   @id @default(cuid())
  eventId     String
  name        String
  description String?
  // Prices stored in kobo (NGN minor units) to avoid float
  priceKobo   Int
  capacity    Int
  sold        Int      @default(0)
  held        Int      @default(0)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event       Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]
  tickets     Ticket[]
}

// ---------- Orders & Tickets ----------

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  EXPIRED
}

model Order {
  id              String      @id @default(cuid())
  userId          String?
  eventId         String
  buyerEmail      String
  buyerPhone      String?
  buyerName       String?
  status          OrderStatus @default(PENDING)
  subtotalKobo    Int
  discountKobo    Int         @default(0)
  promoCode       String?
  feeKobo         Int         @default(0)
  totalKobo       Int
  refundedKobo    Int         @default(0)
  paystackRef     String?     @unique
  paidAt          DateTime?
  expiresAt       DateTime
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user    User?       @relation(fields: [userId], references: [id])
  event   Event       @relation(fields: [eventId], references: [id])
  items   OrderItem[]
  tickets Ticket[]
  refunds Refund[]

  @@index([status, createdAt])
}

enum RefundStatus {
  PENDING
  PROCESSED
  FAILED
}

model Refund {
  id                String       @id @default(cuid())
  orderId           String
  amountKobo        Int
  status            RefundStatus @default(PENDING)
  paystackRefundId  String?
  reason            String?
  createdAt         DateTime     @default(now())
  processedAt       DateTime?
  initiatedById     String?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model OrderItem {
  id           String @id @default(cuid())
  orderId      String
  ticketTypeId String
  quantity     Int
  unitPriceKobo Int

  order      Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id])
}

enum TicketStatus {
  ISSUED
  SCANNED
  VOIDED
}

model Ticket {
  id           String       @id @default(cuid())
  orderId      String
  ticketTypeId String
  // Opaque code embedded in the QR; full ticket data resolves server-side
  code         String       @unique
  status       TicketStatus @default(ISSUED)
  scannedAt    DateTime?
  scannedBy    String?
  createdAt    DateTime     @default(now())

  order      Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id])

  @@index([status])
}
