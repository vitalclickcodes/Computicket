// Computicket Nigeria — Phase 1 schema
// Covers: identity, organizers, events, ticket types, orders, tickets.
// Travel/hotels/vouchers land in later phases.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Identity ----------

enum WalletKycTier {
  NONE
  BASIC
  VERIFIED
}

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  phone             String?  @unique
  name              String?
  passwordHash      String?
  isAdmin           Boolean  @default(false)
  // Cached wallet balance. Source of truth is sum(WalletTransaction.amountKobo).
  walletBalanceKobo Int          @default(0)
  loyaltyPoints     Int          @default(0)
  // Wallet KYC tier (NONE = NGN 50K top-up cap, BASIC = 500K, VERIFIED = unlimited)
  kycTier           WalletKycTier @default(NONE)
  kycSubmittedAt    DateTime?
  kycVerifiedAt     DateTime?
  // Submitted KYC details — admin reviews via the dashboard
  kycBvn            String?
  kycIdNumber       String?
  kycIdDocumentUrl  String?
  // Referral program
  referralCode      String?      @unique
  referredById      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  memberships       OrganizerMember[]
  orders            Order[]
  walletTransactions WalletTransaction[]
  walletTopUps      WalletTopUp[]
  loyaltyTransactions LoyaltyTransaction[]
  agentProfile      AgentProfile?
  referredBy        User?    @relation("UserReferrals", fields: [referredById], references: [id])
  referred          User[]   @relation("UserReferrals")
  referralsMade     Referral[] @relation("Referrer")
  referralReceived  Referral? @relation("Referee")
}

enum ReferralStatus {
  PENDING
  REWARDED
}

model Referral {
  id          String         @id @default(cuid())
  referrerId  String
  refereeId   String         @unique
  status      ReferralStatus @default(PENDING)
  rewardKobo  Int            @default(50000) // NGN 500 default reward
  rewardedAt  DateTime?
  orderId     String?
  createdAt   DateTime       @default(now())

  referrer User @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referee  User @relation("Referee", fields: [refereeId], references: [id], onDelete: Cascade)

  @@index([referrerId])
}

enum WalletTxType {
  TOP_UP
  PURCHASE
  REFUND
  ADJUSTMENT
}

model WalletTransaction {
  id                 String       @id @default(cuid())
  userId             String
  // Positive = credit, negative = debit. Always non-zero.
  amountKobo         Int
  type               WalletTxType
  // Wallet balance after applying this transaction; computed at insert.
  balanceAfterKobo   Int
  // Optional references for traceability.
  orderId            String?
  walletTopUpId      String?
  refundId           String?
  note               String?
  createdAt          DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model AgentProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  agentCode       String   @unique
  // Commission in basis points of order total (default 5%)
  commissionBps   Int      @default(500)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([agentCode])
}

enum LoyaltyTxType {
  EARN
  REDEEM
  ADJUSTMENT
  EXPIRE
}

model LoyaltyTransaction {
  id               String        @id @default(cuid())
  userId           String
  // Signed: positive for EARN/ADJUSTMENT(+), negative for REDEEM/EXPIRE
  points           Int
  type             LoyaltyTxType
  balanceAfter     Int
  orderId          String?
  note             String?
  createdAt        DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

enum WalletTopUpStatus {
  PENDING
  PROCESSED
  FAILED
}

model WalletTopUp {
  id          String            @id @default(cuid())
  userId      String
  amountKobo  Int
  paystackRef String            @unique
  status      WalletTopUpStatus @default(PENDING)
  createdAt   DateTime          @default(now())
  processedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ---------- Organizers (multi-vendor) ----------

enum OrganizerStatus {
  PENDING
  APPROVED
  SUSPENDED
}

enum OrganizerRole {
  OWNER
  MANAGER
  FINANCE
  MARKETING
  SCANNER
  READ_ONLY
}

model Organizer {
  id               String          @id @default(cuid())
  slug             String          @unique
  name             String
  status           OrganizerStatus @default(PENDING)
  description      String?
  logoUrl          String?
  website          String?
  // Paystack split payout integration
  paystackSubaccountCode String?
  payoutBankCode         String?
  payoutAccountNumber    String?
  payoutAccountName      String?
  // KYC / admin review
  kycNotes               String?
  approvedAt             DateTime?
  approvedById           String?
  commissionBps    Int             @default(800) // 8% default
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  members          OrganizerMember[]
  events           Event[]
  apiKeys          ApiKey[]
  webhookEndpoints WebhookEndpoint[]
  promoCodes       PromoCode[]
  busRoutes        BusRoute[]
  affiliateLinks   AffiliateLink[]
  hotels           Hotel[]
  flights          Flight[]
  voucherBatches   VoucherBatch[]
}

model VoucherBatch {
  id            String    @id @default(cuid())
  organizerId   String
  name          String
  denominationKobo Int
  totalCount    Int
  redeemedCount Int       @default(0)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())

  organizer Organizer @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  vouchers  Voucher[]

  @@index([organizerId])
}

model Voucher {
  id            String   @id @default(cuid())
  batchId       String
  code          String   @unique
  redeemedById  String?
  redeemedAt    DateTime?
  createdAt     DateTime @default(now())

  batch VoucherBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
}

model Hotel {
  id              String   @id @default(cuid())
  organizerId     String
  slug            String   @unique
  name            String
  description     String?
  city            String
  address         String
  pricePerNightKobo Int
  capacity        Int
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())

  organizer Organizer @relation(fields: [organizerId], references: [id], onDelete: Cascade)

  @@index([city, active])
}

model Flight {
  id           String   @id @default(cuid())
  organizerId  String
  flightNumber String
  airline      String
  fromAirport  String
  toAirport    String
  departsAt    DateTime
  arrivesAt    DateTime
  priceKobo    Int
  capacity     Int
  sold         Int      @default(0)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  organizer Organizer @relation(fields: [organizerId], references: [id], onDelete: Cascade)

  @@index([fromAirport, toAirport, departsAt])
  @@index([organizerId])
}

model AffiliateLink {
  id          String   @id @default(cuid())
  organizerId String
  code        String
  name        String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  organizer Organizer @relation(fields: [organizerId], references: [id], onDelete: Cascade)

  @@unique([organizerId, code])
  @@index([code])
}

model Broadcast {
  id          String   @id @default(cuid())
  eventId     String
  sentById    String
  subject     String
  body        String   @db.Text
  sentCount   Int      @default(0)
  createdAt   DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, createdAt])
}

model BusRoute {
  id              String   @id @default(cuid())
  organizerId     String
  fromCity        String
  toCity          String
  // Typical trip duration in minutes; used for display and rough arrival estimates.
  durationMinutes Int
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())

  organizer Organizer @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  trips     Event[]

  @@index([fromCity, toCity])
  @@index([organizerId])
}

enum PromoCodeType {
  PERCENTAGE
  FIXED
}

model PromoCode {
  id           String        @id @default(cuid())
  organizerId  String
  // Optional: scope the code to a specific event. NULL = applies to any
  // event owned by this organizer.
  eventId      String?
  code         String
  type         PromoCodeType
  // PERCENTAGE: basis points (1000 = 10%). FIXED: kobo amount off subtotal.
  value        Int
  maxUses      Int?
  usesCount    Int           @default(0)
  expiresAt    DateTime?
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())

  organizer Organizer @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  event     Event?    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([organizerId, code])
  @@index([organizerId])
}

model ApiKey {
  id          String    @id @default(cuid())
  organizerId String
  name        String
  // First 16 chars of the raw key, for display (e.g. "ctng_live_a1b2…")
  prefix      String
  // SHA-256 of the raw key. Indexed for O(1) lookup at request time.
  hashedKey   String    @unique
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  organizer Organizer @relation(fields: [organizerId], references: [id], onDelete: Cascade)

  @@index([organizerId])
}

model WebhookEndpoint {
  id            String   @id @default(cuid())
  organizerId   String
  url           String
  signingSecret String
  // Event names this endpoint subscribes to, e.g. ["order.paid","order.refunded"]
  eventTypes    String[]
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())

  organizer  Organizer          @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([organizerId])
}

enum WebhookDeliveryStatus {
  PENDING
  DELIVERED
  FAILED
}

model WebhookDelivery {
  id             String                @id @default(cuid())
  endpointId     String
  event          String
  eventId        String
  payload        String                @db.Text
  signature      String
  status         WebhookDeliveryStatus @default(PENDING)
  attemptCount   Int                   @default(0)
  lastAttemptAt  DateTime?
  nextAttemptAt  DateTime              @default(now())
  responseStatus Int?
  responseBody   String?               @db.Text
  createdAt      DateTime              @default(now())

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([status, nextAttemptAt])
  @@index([endpointId, createdAt])
}

model OrganizerMember {
  id          String        @id @default(cuid())
  organizerId String
  userId      String
  role        OrganizerRole
  createdAt   DateTime      @default(now())

  organizer Organizer @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizerId, userId])
}

// ---------- Catalog: Events ----------

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum EventType {
  EVENT
  BUS_TRIP
}

model Event {
  id          String      @id @default(cuid())
  organizerId String
  slug        String      @unique
  title       String
  description String?
  venue       String
  city        String
  startsAt    DateTime
  endsAt      DateTime
  coverUrl    String?
  status      EventStatus @default(DRAFT)
  type        EventType   @default(EVENT)
  // For type=BUS_TRIP: optional link to a parent route so buyers can
  // search by from/to. Trips also use venue=boarding terminal,
  // city=fromCity for compatibility with the existing event list.
  busRouteId  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  organizer   Organizer    @relation(fields: [organizerId], references: [id])
  busRoute    BusRoute?    @relation(fields: [busRouteId], references: [id])
  ticketTypes TicketType[]
  orders      Order[]
  promoCodes  PromoCode[]
  addOns      AddOn[]
  broadcasts  Broadcast[]

  @@index([status, startsAt])
  @@index([organizerId])
  @@index([type, status, startsAt])
}

model AddOn {
  id          String   @id @default(cuid())
  eventId     String
  name        String
  description String?
  priceKobo   Int
  capacity    Int?
  sold        Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  event       Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  orderAddOns OrderAddOn[]

  @@index([eventId])
}

model OrderAddOn {
  id            String @id @default(cuid())
  orderId       String
  addOnId       String
  quantity      Int
  unitPriceKobo Int

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  addOn AddOn @relation(fields: [addOnId], references: [id])
}

model TicketType {
  id          String   @id @default(cuid())
  eventId     String
  name        String
  description String?
  // Prices stored in kobo (NGN minor units) to avoid float
  priceKobo   Int
  capacity    Int
  sold        Int      @default(0)
  held        Int      @default(0)
  position    Int      @default(0)
  // Reserved seating: when populated, this tier is seated. Layout is
  // an array of rows: { row: "A", seats: ["1","2","3",...] }. Capacity
  // must equal sum of seats across rows.
  seatMap     Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event       Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]
  tickets     Ticket[]
  seats       Seat[]
}

enum SeatStatus {
  AVAILABLE
  HELD
  SOLD
}

model Seat {
  id           String     @id @default(cuid())
  ticketTypeId String
  // Row + label together are the human seat name (e.g. "A12").
  row          String
  label        String
  status       SeatStatus @default(AVAILABLE)
  // Once SOLD, this links to the ticket that owns this seat.
  ticketId     String?    @unique
  // While HELD, links to the order holding it (released on expiry/refund).
  heldByOrderId String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  ticketType TicketType @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)
  ticket     Ticket?    @relation("TicketSeat", fields: [ticketId], references: [id])

  @@unique([ticketTypeId, row, label])
  @@index([ticketTypeId, status])
}

// ---------- Orders & Tickets ----------

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  EXPIRED
}

model Order {
  id              String      @id @default(cuid())
  userId          String?
  eventId         String
  buyerEmail      String
  buyerPhone      String?
  buyerName       String?
  status          OrderStatus @default(PENDING)
  subtotalKobo    Int
  discountKobo    Int         @default(0)
  promoCode       String?
  feeKobo         Int         @default(0)
  totalKobo       Int
  refundedKobo    Int         @default(0)
  paidFromWallet  Boolean     @default(false)
  affiliateCode   String?
  agentCode       String?
  agentCommissionKobo Int     @default(0)
  loyaltyPointsRedeemed Int   @default(0)
  loyaltyPointsEarned   Int   @default(0)
  paystackRef     String?     @unique
  paidAt          DateTime?
  expiresAt       DateTime
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user    User?        @relation(fields: [userId], references: [id])
  event   Event        @relation(fields: [eventId], references: [id])
  items   OrderItem[]
  addOns  OrderAddOn[]
  tickets Ticket[]
  refunds Refund[]

  @@index([status, createdAt])
}

enum RefundStatus {
  PENDING
  PROCESSED
  FAILED
}

model Refund {
  id                String       @id @default(cuid())
  orderId           String
  amountKobo        Int
  status            RefundStatus @default(PENDING)
  paystackRefundId  String?
  reason            String?
  createdAt         DateTime     @default(now())
  processedAt       DateTime?
  initiatedById     String?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model OrderItem {
  id           String @id @default(cuid())
  orderId      String
  ticketTypeId String
  quantity     Int
  unitPriceKobo Int

  order      Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id])
}

enum TicketStatus {
  ISSUED
  SCANNED
  VOIDED
}

model Ticket {
  id           String       @id @default(cuid())
  orderId      String
  ticketTypeId String
  // Opaque code embedded in the QR; full ticket data resolves server-side
  code         String       @unique
  status       TicketStatus @default(ISSUED)
  scannedAt    DateTime?
  scannedBy    String?
  // Current owner — initialized to Order.userId on issuance, updated by resale.
  ownerUserId  String?
  createdAt    DateTime     @default(now())

  order      Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id])
  seat       Seat?      @relation("TicketSeat")
  listings   TicketListing[]

  @@index([status])
  @@index([ownerUserId])
}

enum TicketListingStatus {
  LISTED
  SOLD
  CANCELLED
}

model TicketListing {
  id          String              @id @default(cuid())
  ticketId    String
  sellerId    String
  askKobo     Int
  status      TicketListingStatus @default(LISTED)
  buyerId     String?
  soldAt      DateTime?
  createdAt   DateTime            @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([ticketId])
}
