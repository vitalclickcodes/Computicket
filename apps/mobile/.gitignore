# Flutter / Dart
.dart_tool/
.packages
build/
.flutter-plugins
.flutter-plugins-dependencies
pubspec.lock

# Platform shells are generated by `flutter create .` on first checkout.
# Keeping them out of source control so the upstream Flutter SDK can
# bump them without polluting our diff — *except* for the two
# permission-bearing manifests we maintain by hand. `flutter create
# --no-overwrite` leaves existing files alone, so checking these in
# pins our camera + internet permission declarations and survives
# every regeneration.
ios/*
!ios/Runner/
ios/Runner/*
!ios/Runner/Info.plist
android/*
!android/app/
android/app/*
!android/app/src/
android/app/src/*
!android/app/src/main/
android/app/src/main/*
!android/app/src/main/AndroidManifest.xml
web/
linux/
macos/
windows/

# IDE
.idea/
.vscode/
*.iml

# OS
.DS_Store
